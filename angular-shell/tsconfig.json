{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strict": false,
    "useDefineForClassFields": false,
    "lib": ["ES2022", "dom"],
    "outDir": "./dist",
    "baseUrl": ".",
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}
